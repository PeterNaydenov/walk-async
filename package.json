{
  "name": "@peter.naydenov/walk-async",
  "version": "3.1.1",
  "description": "Deep copy with fine control during the process. Can be used also as a deep forEach function",
  "main": ".dist/walk-async.umd.js",
  "type": "module",
  "types": "./types/main.d.ts",
  "exports": {
    ".": {
      "import": "./.dist/walk-async.esm.mjs",
      "require": "./.dist/walk-async.cjs",
      "default": "./dist/walk-async.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "cover": "vitest run --coverage",
    "build": "rollup -c",
    "postbuild": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/walk-async.git"
  },
  "author": "Peter Naydenov",
  "license": "MIT",
  "dependencies": {
    "ask-for-promise": "^3.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "rollup": "^4.62.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "3.2.4"
  },
  "vitest": {
    "coverage": {
      "include": [
        "src/**/*.js"
      ],
      "exclude": [
        "node_modules",
        "test",
        "test-data"
      ],
      "reporter": [
        "lcov",
        "text-summary"
      ]
    }
  },
  "browserslist": "> 2%, not dead",
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
